# ─────────────────────────────────────────────────────────────────────────────
# Aftertaste environment variables
#
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
#
# RULE OF THUMB: anything prefixed VITE_ is bundled into the public JavaScript
# and is readable by anyone in browser dev tools. Only PUBLIC values may be VITE_.
# ─────────────────────────────────────────────────────────────────────────────

# ── PUBLIC (safe to ship in the frontend bundle) ────────────────────────────
# These are gated by Supabase Row-Level Security; the anon key grants no data
# access without a valid user session + matching policy.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Feature flag: turn on Google Places restaurant discovery (requires the
# places-search Edge Function deployed + GOOGLE_PLACES_API_KEY secret set).
# Leave false to use the bundled static restaurant catalog (zero cost).
VITE_ENABLE_PLACES=false

# ── SERVER-ONLY (NEVER put these in .env with a VITE_ prefix, NEVER ship them) ─
# Set these as Supabase Edge Function secrets instead:
#   supabase secrets set GOOGLE_PLACES_API_KEY=...
#
#   GOOGLE_PLACES_API_KEY     -> Google Maps/Places API key (Edge Function only)
#   SUPABASE_SERVICE_ROLE_KEY -> bypasses RLS; treat like a root DB password
